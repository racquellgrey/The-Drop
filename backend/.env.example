# ──────────────────────────────────────────────────────────────
#  The Drop — backend/.env.example
#
#  Copy to backend/.env for LOCAL dev only.
#  NEVER commit a real .env. On Vercel, set these as Environment
#  Variables in the project dashboard (Production / Preview / Dev).
# ──────────────────────────────────────────────────────────────

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace_me_locally
DB_NAME=thedrop

# Require TLS to the database. MUST be "true" in production.
DB_SSL=false

# Pool size per serverless instance. Keep small — serverless can
# spin up many concurrent instances.
DB_CONNECTION_LIMIT=3

# --- HTTP ---
PORT=5000

# Comma-separated list of origins allowed to call /api/*.
# Leave blank for same-origin only (the default Vercel setup).
# Example: ALLOWED_ORIGINS=https://the-drop.vercel.app,https://thedrop.example.com
ALLOWED_ORIGINS=

# --- Runtime ---
# Set to "production" in all hosted environments. Vercel sets this
# automatically — you do NOT need to add it in the Vercel dashboard.
NODE_ENV=development
