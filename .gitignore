# ──────────────────────────────────────────────────────────────
#  The Drop — .gitignore
#  NEVER commit credentials, build artifacts, or local tooling.
# ──────────────────────────────────────────────────────────────

# Environment secrets — NEVER commit real credentials
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Node dependencies
node_modules/
**/node_modules/

# Build / coverage / logs
dist/
build/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor & local tooling — may contain saved credentials
.vscode/settings.json
.vscode/*.local.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Vercel
.vercel

# Misc local
*.local
*.pem
*.key
*.p12
*.pfx
